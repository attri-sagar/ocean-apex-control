# =============================================================================
# DigitalOcean Managed PostgreSQL (production / staging)
# =============================================================================
# 1. Create a Managed Database → PostgreSQL in the same region as your app.
# 2. Enable automated backups; note the connection host, port, user, database.
# 3. Download the CA certificate from the database "Connection details" panel.
# 4. Prefer the "Connection pool" URI (PgBouncer) for App Platform / serverless.
#
# Trusted sources: restrict to your Droplet, App Platform egress, or VPC —
# avoid 0.0.0.0/0 for production.
#
# Example (adjust user, password, db name, host):
# DATABASE_URL=postgresql://doadmin:PASSWORD@private-db-host:25060/defaultdb?sslmode=require
#
# Point SSL verification at the downloaded CA file (required for verify-full style setups):
# PGSSLROOTCERT=/absolute/path/to/ca-certificate.crt
#
# If you use a pooler URL that already embeds ssl parameters, still set PGSSLROOTCERT
# when the provider requires custom CA verification.

# =============================================================================
# Local development (Docker Compose)
# =============================================================================
# Run: docker compose up -d
# Then: cp .env.example .env
# Smoke test DB: npm run smoke   (runs db:migrate + connection/schema checks)
# Without Docker: npm run smoke:static   (vitest + server TS check only)
DATABASE_URL=postgresql://ocean:ocean@127.0.0.1:5432/ocean_apex
# Local Postgres typically has no TLS; disable SSL for the driver:
DATABASE_SSL=disable

# Webhook auth for /functions/v1/ai-tasks (must match client VITE_CLAWBUDDY_WEBHOOK_SECRET in dev)
CLAWBUDDY_WEBHOOK_SECRET=dev-local-secret

# Browser → Vite dev server (public value only)
VITE_CLAWBUDDY_WEBHOOK_SECRET=dev-local-secret

# =============================================================================
# Built-in RSS reader (Threat Intel tab) — server-side only, no secrets
# =============================================================================
# Comma-separated feed URLs (http/https). Labels default to the hostname.
# RSS_FEED_URLS=https://krebsonsecurity.com/feed/,https://example.com/rss.xml
#
# Or JSON array with explicit labels:
# RSS_FEEDS_JSON=[{"url":"https://krebsonsecurity.com/feed/","label":"Krebs"}]
#
# Cache TTL for parsed feeds in milliseconds (default 600000 = 10 minutes).
# RSS_CACHE_TTL_MS=600000
